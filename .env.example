# ──────────────────────────────────────────────────────────────────────────────
# Loop Environment Configuration
# Copy this file to .env and fill in production values.
# ──────────────────────────────────────────────────────────────────────────────

# ── Core (§10.1) ──────────────────────────────────────────────────────────────
LOOP_PORT=3000
LOOP_HOST=0.0.0.0
LOOP_LOG_LEVEL=info
LOOP_ENV=production
LOOP_DATA_DIR=/var/lib/loop
# AES-256 master key — generate with: openssl rand -base64 32
LOOP_ENCRYPTION_KEY=CHANGE_ME_TO_A_RANDOM_32_CHAR_STRING_

# ── Database (§10.2) ──────────────────────────────────────────────────────────
# Core tier uses SQLite (default). Scale tier uses PostgreSQL.
LOOP_DB_TYPE=sqlite
LOOP_DB_PATH=/var/lib/loop/loop.db
# LOOP_DB_HOST=postgres.internal
# LOOP_DB_PORT=5432
# LOOP_DB_NAME=loop
# LOOP_DB_USER=loop_app
# LOOP_DB_PASSWORD=
# LOOP_DB_SSL=true

# ── Redis (§10.3 — Scale tier only) ──────────────────────────────────────────
# LOOP_REDIS_URL=redis://redis.internal:6379
# LOOP_REDIS_PASSWORD=
# LOOP_REDIS_TLS=true

# ── Execution Engine (§10.4) ──────────────────────────────────────────────────
LOOP_MAX_CONCURRENT=50
LOOP_EXECUTION_TIMEOUT_MS=300000
LOOP_NODE_TIMEOUT_MS=30000
LOOP_DEFAULT_RETRY_COUNT=3
LOOP_DEFAULT_BACKOFF=exponential

# ── Sandbox (§10.5) ──────────────────────────────────────────────────────────
LOOP_SANDBOX_TYPE=gvisor
LOOP_SANDBOX_URL=http://loop-sandbox:4000
LOOP_SANDBOX_MEMORY_MB=256
LOOP_SANDBOX_CPU_SECONDS=30
LOOP_SANDBOX_POOL_SIZE=3

# ── LLM Providers (§10.6) ────────────────────────────────────────────────────
LOOP_LLM_PRIMARY=ollama
LOOP_LLM_OLLAMA_URL=http://localhost:11434
# LOOP_LLM_OPENAI_KEY=sk-...
# LOOP_LLM_ANTHROPIC_KEY=sk-ant-...
LOOP_LLM_FALLBACK_CHAIN=ollama,openai,anthropic

# ── ODW Agent Connections (§10.7) ────────────────────────────────────────────
# LOOP_VAULT_URL=http://vault:8080
# LOOP_VAULT_API_KEY=
# LOOP_DESK_URL=http://desk:8080
# LOOP_DESK_API_KEY=
# LOOP_RECAP_URL=http://recap:8080
# LOOP_RECAP_API_KEY=

# ── Auth & Security (§10.8) ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
LOOP_JWT_SECRET=CHANGE_ME_TO_A_RANDOM_STRING
LOOP_JWT_ACCESS_TTL=15m
LOOP_JWT_REFRESH_TTL=7d

# ── Egress & Sovereignty (§10.9) ─────────────────────────────────────────────
LOOP_EGRESS_DEFAULT_POLICY=deny
LOOP_AIRGAP_MODE=false
# LOOP_ALLOWED_REGIONS=eu-west,eu-central

# ── Observability (§10.10) ───────────────────────────────────────────────────
LOOP_METRICS_ENABLED=true
LOOP_OTEL_ENABLED=false
# LOOP_OTEL_ENDPOINT=http://otel:4317
# LOOP_ALERT_WEBHOOK_URL=https://hooks.slack.com/...

# ── Scale Tier / Control Plane (§10.11) ──────────────────────────────────────
# LOOP_INSTANCE_ID=loop-frankfurt-1
# LOOP_REGION=eu-central-1
# LOOP_CONTROL_PLANE_URL=https://control.loop.internal
# LOOP_CLUSTER_TOKEN=
