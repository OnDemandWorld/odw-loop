{
  "name": "@loop/state",
  "version": "1.0.0",
  "description": "State store abstraction with SQLite and PostgreSQL adapters for Loop",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@loop/types": "workspace:*",
    "@loop/observability": "workspace:*",
    "drizzle-orm": "^0.29.0",
    "better-sqlite3": "^12.0.0",
    "pg": "^8.11.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/pg": "^8.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "drizzle-kit": "^0.20.0"
  }
}
