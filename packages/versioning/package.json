{
  "name": "@loop/versioning",
  "version": "1.0.0",
  "description": "Git-backed version management for workflow definitions",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@loop/types": "workspace:*",
    "@loop/observability": "workspace:*",
    "@loop/state": "workspace:*",
    "isomorphic-git": "^1.25.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
