# Test environment — used by vitest
LOOP_ENV=test
LOOP_LOG_LEVEL=fatal
LOOP_DB_TYPE=sqlite
LOOP_DB_PATH=:memory:
LOOP_DATA_DIR=/tmp/loop-test
LOOP_ENCRYPTION_KEY=test-key-must-be-at-least-32-characters-long!
LOOP_JWT_SECRET=test-jwt-secret
LOOP_MAX_CONCURRENT=5
LOOP_EXECUTION_TIMEOUT_MS=10000
LOOP_NODE_TIMEOUT_MS=5000
LOOP_DEFAULT_RETRY_COUNT=1
LOOP_DEFAULT_BACKOFF=fixed
LOOP_EGRESS_DEFAULT_POLICY=allow
LOOP_AIRGAP_MODE=false
LOOP_METRICS_ENABLED=false
