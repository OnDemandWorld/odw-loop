{
  "name": "@loop/sandbox",
  "version": "1.0.0",
  "description": "Loop Sandbox — isolated code execution (gVisor/Firecracker) for Python/TypeScript",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc --build",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@loop/types": "workspace:*",
    "@loop/observability": "workspace:*",
    "@loop/egress": "workspace:*",
    "fastify": "^4.25.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "tsx": "^4.7.0",
    "vitest": "^1.0.0"
  }
}
