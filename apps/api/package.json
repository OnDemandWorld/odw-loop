{
  "name": "@loop/api",
  "version": "1.0.0",
  "description": "Loop API server — Fastify HTTP/WS hosting all @loop/* modules",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc --build",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@loop/types": "workspace:*",
    "@loop/state": "workspace:*",
    "@loop/engine": "workspace:*",
    "@loop/connectors": "workspace:*",
    "@loop/triggers": "workspace:*",
    "@loop/secrets": "workspace:*",
    "@loop/egress": "workspace:*",
    "@loop/observability": "workspace:*",
    "@loop/llm": "workspace:*",
    "@loop/workflow-authoring": "workspace:*",
    "@loop/versioning": "workspace:*",
    "fastify": "^4.25.0",
    "@fastify/cors": "^8.5.0",
    "@fastify/websocket": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "jose": "^5.2.0",
    "bcrypt": "^5.1.0",
    "zod": "^3.22.0",
    "pino": "^8.17.0",
    "pino-pretty": "^10.3.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0",
    "vitest": "^1.0.0"
  }
}
